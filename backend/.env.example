# Provider API keys (leave blank to force MOCK_MODE for that provider)
ANTHROPIC_API_KEY=
HUME_API_KEY=
GOOGLE_API_KEY=

# Global mock toggle: when true, no external AI calls are made.
# Can also be flipped at runtime via POST /api/mock/toggle.
MOCK_MODE=true

# SQLite location. ":memory:" works but loses state on reload.
DB_URL=sqlite:///./consent.db

# Port the API listens on.
PORT=8000
